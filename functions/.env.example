# ─── Razorpay (SERVER-SIDE — never expose these in the mobile app) ──────────
# Test keys: razorpay.com/dashboard > Settings > API Keys
# Switch to live keys when bank account is activated
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_TEST_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_TEST_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_YOUR_WEBHOOK_SECRET

# Razorpay Subscription Plan IDs (create in Razorpay Dashboard > Products > Plans)
RAZORPAY_PLAN_MONTHLY=plan_REPLACE_WITH_MONTHLY_PLAN_ID
RAZORPAY_PLAN_QUARTERLY=plan_REPLACE_WITH_QUARTERLY_PLAN_ID
RAZORPAY_PLAN_ANNUAL=plan_REPLACE_WITH_ANNUAL_PLAN_ID

# ─── Stripe (SERVER-SIDE — never expose these in the mobile app) ─────────────
# Test keys: dashboard.stripe.com > Developers > API Keys
# Switch to live keys when Stripe account is verified
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_SECRET
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRICE_MONTHLY=price_REPLACE_WITH_MONTHLY_PRICE_ID
STRIPE_PRICE_QUARTERLY=price_REPLACE_WITH_QUARTERLY_PRICE_ID
STRIPE_PRICE_ANNUAL=price_REPLACE_WITH_ANNUAL_PRICE_ID
STRIPE_PRICE_LIFETIME=price_REPLACE_WITH_LIFETIME_PRICE_ID

# App deep-link scheme (must match app.config.js scheme)
APP_SCHEME=vitalnoteai
