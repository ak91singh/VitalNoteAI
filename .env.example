# VitalNoteAI — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ─── AI / Transcription ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
HF_API_TOKEN=hf_REPLACE_WITH_YOUR_HF_TOKEN
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_OPENROUTER_KEY

# ─── Firebase Functions URL ────────────────────────────────────────────────
# Set to your Firebase project's Functions base URL after first deploy.
# Format: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net
# Your project ID is: vitalnoteai-prod
FIREBASE_FUNCTIONS_URL=https://us-central1-vitalnoteai-prod.cloudfunctions.net
